{
  "name": "prompt-anatomy-training",
  "version": "1.4.5",
  "description": "Interaktyvus DI promptų mokymas: MVP M1–6, production M1–9 (tier 9), full authoring katalogas M1–15. Praktika, apklausa, sertifikatai.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:production": "cross-env VITE_MAX_BUILD_MODULE=9 vite build",
    "build:corporate": "npm run build:production",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --report-unused-disable-directives --max-warnings 0",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "validate:schema": "node scripts/validate-schema.mjs",
    "validate:journey-m7": "node scripts/validate-journey-m7.mjs",
    "validate:journey-en-m7": "node scripts/validate-journey-en-m7.mjs",
    "audit:m7-journey-coverage": "node scripts/audit-m7-journey-coverage.mjs",
    "audit:m7-journey-coverage:en": "node scripts/audit-m7-journey-coverage.mjs --locale=en",
    "generate:core-data": "node scripts/generate-core-data.mjs",
    "audit:slide-interactivity": "node scripts/audit-slide-interactivity.mjs",
    "audit:embed-catalog": "node scripts/audit-slide-interactivity.mjs --embed-catalog",
    "audit:test-scenario-share": "node scripts/audit-test-scenario-share.mjs",
    "audit:accent-budget": "node scripts/audit-accent-budget.mjs",
    "audit:accent-budget:m1012": "node scripts/audit-accent-budget.mjs --modules=10,11,12",
    "audit:slide-titles": "node scripts/audit-slide-titles.mjs",
    "audit:collapsible": "node scripts/audit-collapsible-sections.mjs",
    "audit:markdown-tables": "node scripts/audit-markdown-tables.mjs",
    "audit:long-no-collapsible": "node scripts/audit-long-without-collapsible.mjs",
    "audit:heading-time": "node scripts/audit-heading-time-ambiguity.mjs",
    "audit:footer-numbers": "node scripts/audit-footer-numbers.mjs",
    "audit:en-coverage-m10-12": "node scripts/audit-en-coverage-m10-12.mjs",
    "audit:en-language-m10-12": "node scripts/audit-en-language-m10-12.mjs",
    "audit:m1012": "npm run audit:en-coverage-m10-12 && npm run audit:en-language-m10-12",
    "audit:en-coverage-m13-15": "node scripts/audit-en-coverage-m13-15.mjs",
    "audit:en-language-m13-15": "node scripts/audit-en-language-m13-15.mjs",
    "audit:m1315": "npm run audit:en-coverage-m13-15 && npm run audit:en-language-m13-15",
    "audit:en-coverage-m4-m6": "node scripts/audit-en-coverage-m4-m6.mjs",
    "audit:en-language-m4-m6": "node scripts/audit-en-language-m4-m6.mjs",
    "audit:m46": "npm run audit:en-coverage-m4-m6 && npm run audit:en-language-m4-m6",
    "audit:en-coverage-m7-m9": "node scripts/audit-en-coverage-m7-m9.mjs",
    "audit:en-language-m7-m9": "node scripts/audit-en-language-m7-m9.mjs",
    "audit:m79": "npm run audit:en-coverage-m7-m9 && npm run audit:en-language-m7-m9 && npm run audit:markdown-tables",
    "audit:nav-labels": "node scripts/audit-nav-labels.mjs",
    "audit:m7-pathbranch": "node scripts/audit-m7-pathbranch.mjs",
    "audit:m7-journey-indices": "node scripts/audit-m7-journey-indices.mjs",
    "audit:m49": "npm run audit:m46 && npm run audit:m79",
    "audit:release-preflight": "npm run validate:schema && npm run lint && npm run audit:design-tokens:gate && npm run audit:module-identity && npm run audit:slide-icons && npm run audit:accent-budget && npm run audit:slide-titles && npm run audit:m49 && npm run audit:nav-labels && npm run audit:m7-pathbranch && npm run validate:journey-m7 && npm run validate:journey-en-m7 && npm run audit:m7-journey-coverage && npm run audit:m7-journey-coverage:en && npm run audit:m7-journey-indices && npm run test:run",
    "extract:modules-en-m10-m12": "node scripts/extract-modules-m10-m12.mjs",
    "build:modules-en-m10-m12": "node scripts/build-en-m10-m12.mjs",
    "extract:modules-en-m13-m15": "node scripts/extract-modules-m13-m15.mjs",
    "build:modules-en-m13-m15": "node scripts/build-en-m13-m15.mjs",
    "build:modules-en-m7-m9": "node scripts/build-en-m7-m9.mjs",
    "audit:design-tokens": "node scripts/audit-design-tokens.mjs",
    "audit:design-tokens:gate": "node scripts/audit-design-tokens.mjs --fail-on-regression",
    "audit:module-identity": "node scripts/audit-module-identity.mjs",
    "audit:slide-icons": "node scripts/audit-slide-icons.mjs",
    "export:seo-snippets": "node scripts/export-public-seo-snippets.mjs",
    "fonts:satori": "node scripts/fetch-satori-fonts.mjs",
    "generate:portal-beats": "node scripts/generate-portal-beats.mjs",
    "typecheck": "tsc --noEmit",
    "analyze": "cross-env ANALYZE=true vite build",
    "prebuild": "npm run validate:schema",
    "prepare": "husky"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.4",
    "i18next": "^25.8.14",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^16.5.6"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.2.8",
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.1.0",
    "@vitest/ui": "^1.1.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.4.16",
    "axe-core": "^4.11.1",
    "cross-env": "^10.1.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.0",
    "jsdom": "^23.0.1",
    "lint-staged": "^15.2.10",
    "postcss": "^8.4.32",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^6.0.11",
    "satori": "^0.12.2",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vitest": "^1.1.0"
  },
  "keywords": [
    "prompt-engineering",
    "ai-training",
    "react",
    "typescript",
    "business-training",
    "interactive-learning"
  ],
  "author": "Tomas Staniulis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DITreneris/inzinerija.git"
  },
  "bugs": {
    "url": "https://github.com/DITreneris/inzinerija/issues"
  },
  "homepage": "https://ditreneris.github.io/inzinerija/",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ],
    "src/data/*.json": [
      "node scripts/validate-schema.mjs"
    ]
  }
}
