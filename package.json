{
  "name": "prompt-anatomy-training",
  "version": "1.2.0",
  "description": "6 promptų struktūros blokai, vienas nuoseklus mokymas – sistema nuo A iki Z. Interaktyvus DI mokymas: 6 moduliai, praktika, apklausa.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --report-unused-disable-directives --max-warnings 0",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "validate:schema": "node scripts/validate-schema.mjs",
    "generate:core-data": "node scripts/generate-core-data.mjs",
    "audit:collapsible": "node scripts/audit-collapsible-sections.mjs",
    "audit:long-no-collapsible": "node scripts/audit-long-without-collapsible.mjs",
    "audit:heading-time": "node scripts/audit-heading-time-ambiguity.mjs",
    "audit:footer-numbers": "node scripts/audit-footer-numbers.mjs",
    "typecheck": "tsc --noEmit",
    "analyze": "ANALYZE=true vite build",
    "prebuild": "npm run validate:schema",
    "prepare": "husky"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.4",
    "i18next": "^25.8.14",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^16.5.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/react": "^18.2.43",
    "@types/node": "^20.10.0",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.1.0",
    "@vitest/ui": "^1.1.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.4.16",
    "axe-core": "^4.11.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "husky": "^9.1.7",
    "jsdom": "^23.0.1",
    "lint-staged": "^16.3.3",
    "postcss": "^8.4.32",
    "rollup-plugin-visualizer": "^6.0.11",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vitest": "^1.1.0"
  },
  "keywords": [
    "prompt-engineering",
    "ai-training",
    "react",
    "typescript",
    "business-training",
    "interactive-learning"
  ],
  "author": "Tomas Staniulis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DITreneris/inzinerija.git"
  },
  "bugs": {
    "url": "https://github.com/DITreneris/inzinerija/issues"
  },
  "homepage": "https://ditreneris.github.io/inzinerija/",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
