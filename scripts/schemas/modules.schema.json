{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://prompt-anatomy.local/schemas/modules.json",
  "title": "Modules data (modules.json)",
  "description": "Root structure: modules array and quiz. Per-slide required fields depend on slide type (e.g. content-block requires content.sections).",
  "type": "object",
  "required": ["modules", "quiz"],
  "properties": {
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/module" }
    },
    "quiz": { "$ref": "#/$defs/quiz" }
  },
  "$defs": {
    "journeyIconKey": {
      "type": "string",
      "enum": [
        "TrendingUp",
        "Image",
        "Cpu",
        "Users",
        "Briefcase",
        "Compass",
        "Sparkles",
        "Database"
      ]
    },
    "introPieIconKey": {
      "type": "string",
      "enum": [
        "Pen",
        "Wrench",
        "Search",
        "Code",
        "Image",
        "HelpCircle",
        "Brain",
        "Target",
        "Database",
        "BarChart3",
        "Workflow"
      ]
    },
    "summaryIconKey": {
      "type": "string",
      "enum": [
        "Layers",
        "Workflow",
        "Repeat",
        "Lightbulb",
        "ArrowRight",
        "Target",
        "Sparkles",
        "Zap",
        "Compass",
        "Image",
        "Video",
        "Music",
        "Briefcase",
        "Users"
      ]
    },
    "scenarioHubIconKey": {
      "type": "string",
      "enum": ["User", "Users", "Briefcase", "Bot", "BarChart3", "Image"]
    },
    "infographicIconKey": {
      "type": "string",
      "enum": [
        "Pen",
        "Code",
        "Headphones",
        "Search",
        "Megaphone",
        "Wrench",
        "Zap",
        "Users",
        "Target",
        "BarChart3",
        "Database",
        "Link",
        "ClipboardList",
        "Bot",
        "Key"
      ]
    },
    "module": {
      "type": "object",
      "required": [
        "id",
        "title",
        "subtitle",
        "description",
        "icon",
        "level",
        "duration",
        "slides",
        "businessExamples"
      ],
      "properties": {
        "id": { "type": "number" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "description": { "type": "string", "maxLength": 120 },
        "icon": {
          "type": "string",
          "enum": [
            "BookOpen",
            "ClipboardList",
            "Briefcase",
            "Brain",
            "ClipboardCheck",
            "Rocket",
            "BarChart3",
            "Cpu",
            "Image"
          ],
          "description": "ModulesPage kortelės ikona (Lucide). Privalo sutapti su identityIcon, kai pastarasis nurodytas (DS v0.3.1)."
        },
        "level": { "enum": ["learn", "test", "practice"] },
        "duration": { "type": "string" },
        "slides": {
          "type": "array",
          "items": { "$ref": "#/$defs/slide" }
        },
        "businessExamples": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "description"],
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "unlocksAfter": {
          "type": "number",
          "description": "Modulio ID, po kurio šis modulis atrakinamas"
        },
        "accent": {
          "type": "string",
          "enum": [
            "brand",
            "slate",
            "emerald",
            "violet",
            "cyan",
            "accent",
            "sky",
            "fuchsia",
            "rose"
          ],
          "description": "Modulio identiteto accent. Optional. M1–M6 spektras (DS v0.2 §1); M7–M15 per taką (DS v0.3): sky=Duomenų analizė, fuchsia=Agentai, rose=Turinys."
        },
        "identityIcon": {
          "type": "string",
          "enum": [
            "BookOpen",
            "ClipboardList",
            "Briefcase",
            "Brain",
            "ClipboardCheck",
            "Rocket",
            "BarChart3",
            "Cpu",
            "Image"
          ],
          "description": "Lucide identity icon name. Optional. M1–M15 (DS v0.2 §1 + DS v0.3 plėtra)."
        }
      }
    },
    "slide": {
      "type": "object",
      "required": ["id", "title", "subtitle", "type"],
      "properties": {
        "id": { "type": "number" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "type": {
          "type": "string",
          "enum": [
            "action-intro",
            "action-intro-journey",
            "intro",
            "definitions",
            "prompt-types",
            "prompt-techniques",
            "workflow-summary",
            "prompt-template",
            "transition-3-to-6",
            "hierarchy",
            "meta",
            "input",
            "output",
            "reasoning-models",
            "reasoning",
            "quality",
            "advanced",
            "advanced-2",
            "full-example",
            "comparison",
            "summary",
            "test-intro",
            "test-section",
            "test-results",
            "practice-intro",
            "practice-scenario",
            "practice-scenario-hub",
            "practice-summary",
            "infographic",
            "hallucination-dashboard",
            "hallucination-pipeline",
            "ai-detectors",
            "di-modalities",
            "pie-chart",
            "intro-action-pie",
            "ai-workflow",
            "module-intro",
            "content-block",
            "evaluator-prompt-block",
            "glossary",
            "section-break",
            "warm-up-quiz",
            "path-step",
            "vaizdo-generatorius"
          ]
        },
        "shortTitle": { "type": "string" },
        "blockNumber": { "type": "number" },
        "keyQuestion": { "type": "string" },
        "optional": { "type": "boolean" },
        "pathBranch": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Teminių šakų id (M7 keliai, Lygis B). Nurodyta = skaidrė rodoma tik kai pasirinktas fokusas turi sutampančią šaką; nenurodyta = branduolio skaidrė."
        },
        "content": { "$ref": "#/$defs/slideContent" },
        "testQuestions": {
          "type": "array",
          "items": { "$ref": "#/$defs/testQuestion" }
        },
        "scenario": { "$ref": "#/$defs/scenario" },
        "practicalTask": { "$ref": "#/$defs/practicalTask" },
        "characterId": {
          "type": "number",
          "minimum": 1,
          "maximum": 4,
          "description": "M9 role-quest: veikėjas 1–4 atlieka šį scenarijų"
        },
        "recommended": {
          "type": "boolean",
          "description": "M9/M10/… rekomenduojamas pradedantiesiems"
        },
        "badgeVariant": {
          "type": "string",
          "enum": ["bonus", "optional"],
          "description": "Optional badge tipas: bonus (Sparkles) arba optional (Neprivaloma)"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "content-block" } },
            "required": ["type"]
          },
          "then": {
            "required": ["content"],
            "properties": {
              "content": {
                "type": "object",
                "required": ["sections"],
                "properties": {
                  "sections": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "required": ["body"],
                      "properties": {
                        "heading": { "type": "string" },
                        "body": { "type": "string" },
                        "copyable": { "type": "string" },
                        "collapsible": { "type": "boolean" },
                        "blockVariant": {
                          "type": "string",
                          "enum": [
                            "accent",
                            "brand",
                            "terms",
                            "emerald",
                            "violet",
                            "default"
                          ]
                        },
                        "image": { "type": "string" },
                        "imageAlt": { "type": "string" },
                        "figmaUrl": {
                          "type": "string",
                          "description": "Figma embed URL – rodomas kaip iframe"
                        },
                        "table": { "type": "object" },
                        "linkedRowIndex": {
                          "type": "integer",
                          "minimum": 0,
                          "description": "Susieti copyable sekciją su toolChoiceBar eilute"
                        },
                        "toolChoiceBar": {
                          "type": "object",
                          "properties": {
                            "question": { "type": "string" },
                            "choices": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "required": ["label", "rowIndex"],
                                "properties": {
                                  "label": { "type": "string" },
                                  "rowIndex": {
                                    "type": "integer",
                                    "minimum": 0
                                  }
                                }
                              }
                            }
                          }
                        },
                        "presentationToolsBlock": { "type": "boolean" }
                      }
                    }
                  },
                  "toolsIntro": { "type": "string" },
                  "toolsCollapsible": {
                    "type": "boolean",
                    "description": "Įrankių blokas – details/summary (pvz. M7 skaidrė 71)"
                  },
                  "tools": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["name"],
                      "properties": {
                        "name": { "type": "string" },
                        "url": { "type": "string" },
                        "description": { "type": "string" },
                        "useCases": {
                          "type": "array",
                          "items": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "evaluator-prompt-block" } },
            "required": ["type"]
          },
          "then": {
            "required": ["content"],
            "properties": {
              "content": {
                "type": "object",
                "required": ["sections", "practicalTask"],
                "description": "Pedagogika: vienas promptas (vertintojas) vertina kitą; copyable = vertintojo promptas, practicalTask = žingsniai (ne to paties teksto dubliavimas). Tinka vertinimui, manipuliacijoms, haliucinacijoms.",
                "properties": {
                  "sections": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "required": ["body"],
                      "properties": {
                        "heading": { "type": "string" },
                        "body": { "type": "string" },
                        "copyable": { "type": "string" },
                        "collapsible": { "type": "boolean" },
                        "blockVariant": {
                          "type": "string",
                          "enum": [
                            "accent",
                            "brand",
                            "terms",
                            "emerald",
                            "violet",
                            "default"
                          ]
                        },
                        "image": { "type": "string" },
                        "imageAlt": { "type": "string" },
                        "figmaUrl": { "type": "string" },
                        "table": { "type": "object" }
                      }
                    }
                  },
                  "practicalTask": { "$ref": "#/$defs/practicalTask" }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "intro-action-pie" } },
            "required": ["type"]
          },
          "then": {
            "required": ["content"],
            "properties": {
              "content": {
                "type": "object",
                "required": ["question", "segments"],
                "properties": {
                  "question": { "type": "string" },
                  "subtitle": { "type": "string" },
                  "introHook": { "type": "string" },
                  "ctaReveal": { "type": "string" },
                  "chartHeading": { "type": "string" },
                  "hidePdfActions": { "type": "boolean" },
                  "footer": { "type": "string" },
                  "segments": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "required": ["label", "value"],
                      "properties": {
                        "label": { "type": "string" },
                        "value": { "type": "number" },
                        "colorKey": { "type": "string" }
                      }
                    }
                  },
                  "cards": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["icon", "title"],
                      "properties": {
                        "icon": { "$ref": "#/$defs/introPieIconKey" },
                        "title": { "type": "string" },
                        "description": { "type": "string" }
                      }
                    }
                  },
                  "revealInsights": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "segmentPhrase": { "type": "string" },
                        "insight": { "type": "string" },
                        "question": { "type": "string" },
                        "line1": { "type": "string" },
                        "line2": { "type": "string" },
                        "ctaLabel": { "type": "string" },
                        "ctaHref": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "practice-scenario-hub" } },
            "required": ["type"]
          },
          "then": {
            "required": ["content"],
            "properties": {
              "content": { "$ref": "#/$defs/practiceScenarioHubContent" }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "infographic" } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "content": {
                "type": "object",
                "properties": {
                  "portalBrand": {
                    "type": "string",
                    "description": "Optional masthead brand (e.g. Next Level AI) – portal feel"
                  },
                  "portalMeta": {
                    "type": "object",
                    "description": "Editorial metadata – byline, date, read time (Portal 2.1)",
                    "properties": {
                      "byline": { "type": "string" },
                      "publishedAt": { "type": "string" },
                      "readMinutes": { "type": "number", "minimum": 1 }
                    }
                  },
                  "portalNav": {
                    "type": "array",
                    "description": "Decorative portal nav links (max 7 recommended)",
                    "maxItems": 7,
                    "items": {
                      "type": "object",
                      "required": ["label"],
                      "properties": {
                        "label": { "type": "string" }
                      }
                    }
                  },
                  "breakingTicker": {
                    "type": "string",
                    "description": "Optional breaking news ticker (Portal 2.1)"
                  },
                  "heroSidebarTeasers": {
                    "type": "array",
                    "description": "Hero sidebar story teasers (3 recommended)",
                    "maxItems": 5,
                    "items": {
                      "type": "object",
                      "required": ["headline"],
                      "properties": {
                        "eyebrow": { "type": "string" },
                        "headline": { "type": "string" },
                        "readMinutes": { "type": "number", "minimum": 1 },
                        "scrollTarget": {
                          "type": "string",
                          "enum": [
                            "portal-section-data",
                            "portal-beat-awareness",
                            "portal-beat-lithuania",
                            "portal-section-depth",
                            "portal-section-close"
                          ],
                          "description": "In-page scroll target for sidebar teaser jump (M4 sk. 53.5)"
                        }
                      }
                    }
                  },
                  "immersive": {
                    "type": "boolean",
                    "description": "When true, ModuleView hides course H1/badge for portal immersion"
                  },
                  "editorialBeats": {
                    "type": "array",
                    "description": "Editorial pauses between data blocks (no CTA); max 3 recommended",
                    "items": {
                      "type": "object",
                      "required": ["id", "title", "body", "placement"],
                      "properties": {
                        "id": { "type": "string" },
                        "title": { "type": "string" },
                        "body": { "type": "string" },
                        "image": { "$ref": "#/$defs/portalImageSlot" },
                        "side": { "type": "string", "enum": ["left", "right"] },
                        "accentKey": {
                          "type": "string",
                          "enum": ["brand", "accent", "violet", "emerald"]
                        },
                        "placement": {
                          "type": "string",
                          "enum": [
                            "afterHero",
                            "afterKpi",
                            "afterSections",
                            "beforeCta"
                          ]
                        }
                      }
                    }
                  },
                  "promoRibbons": {
                    "type": "array",
                    "description": "Promo ribbon strips (eyebrow + one message)",
                    "items": {
                      "type": "object",
                      "required": ["eyebrow", "title", "placement"],
                      "properties": {
                        "eyebrow": { "type": "string" },
                        "title": { "type": "string" },
                        "subline": { "type": "string" },
                        "stat": {
                          "type": "object",
                          "required": ["value", "label"],
                          "properties": {
                            "value": { "type": "string" },
                            "label": { "type": "string" }
                          }
                        },
                        "variant": {
                          "type": "string",
                          "enum": ["brand", "accent"]
                        },
                        "placement": {
                          "type": "string",
                          "enum": ["afterKpi", "beforeInsight"]
                        }
                      }
                    }
                  },
                  "ctaBlock": {
                    "type": "object",
                    "description": "Optional single CTA block – invitation to act",
                    "properties": {
                      "label": { "type": "string" },
                      "subline": { "type": "string" }
                    },
                    "required": ["label"]
                  },
                  "takeaway": { "type": "string" },
                  "takeawayCta": {
                    "type": "string",
                    "description": "Optional CTA line below takeaway – new line, bold, accent gradient"
                  },
                  "heroImageVertical": { "$ref": "#/$defs/portalImageSlot" },
                  "bannerImageHorizontal": {
                    "$ref": "#/$defs/portalImageSlot"
                  },
                  "bannerBetweenKpiAndSections": {
                    "$ref": "#/$defs/portalImageSlot"
                  },
                  "sectionCards": {
                    "type": "array",
                    "description": "Legacy: 3 section cards. When mainInsightBlock + secondaryCards present, 2-level layout is used instead.",
                    "items": {
                      "type": "object",
                      "properties": {
                        "imageVertical": { "$ref": "#/$defs/portalImageSlot" }
                      }
                    }
                  },
                  "mainInsightBlock": {
                    "type": "object",
                    "description": "Level 1: full-width main insight (one number + one line). Used with secondaryCards for 2-level layout.",
                    "required": ["bigNumber", "label"],
                    "properties": {
                      "bigNumber": { "type": "string" },
                      "label": { "type": "string" },
                      "source": { "type": "string" },
                      "imageVertical": { "$ref": "#/$defs/portalImageSlot" }
                    }
                  },
                  "secondaryCards": {
                    "type": "array",
                    "description": "Level 2: exactly 2 small KPI cards. Used with mainInsightBlock for 2-level layout.",
                    "minItems": 2,
                    "maxItems": 2,
                    "items": {
                      "type": "object",
                      "required": ["sectionLabel", "title", "value", "label"],
                      "properties": {
                        "sectionLabel": { "type": "string" },
                        "title": { "type": "string" },
                        "value": { "type": "string" },
                        "label": { "type": "string" },
                        "source": { "type": "string" },
                        "colorKey": {
                          "type": "string",
                          "enum": ["brand", "violet", "emerald", "amber"]
                        },
                        "imageVertical": { "$ref": "#/$defs/portalImageSlot" }
                      }
                    }
                  },
                  "toolsAndYouth": {
                    "type": "object",
                    "properties": {
                      "youthImageVertical": {
                        "$ref": "#/$defs/portalImageSlot"
                      }
                    }
                  },
                  "insightCard": {
                    "type": "object",
                    "properties": {
                      "illustrationHorizontal": {
                        "$ref": "#/$defs/portalImageSlot"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "section-break" } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "content": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "subtitle": { "type": "string" },
                  "sectionNumber": { "type": "string" },
                  "footer": { "type": "string" },
                  "recap": {
                    "type": "object",
                    "properties": {
                      "heading": { "type": "string" },
                      "lead": {
                        "type": "string",
                        "description": "Neprivaloma įvadinė eilutė virš punktų (pvz. „Promptų inžinerija – kaip knyga.“)"
                      },
                      "items": {
                        "type": "array",
                        "items": { "type": "string" }
                      },
                      "itemGlossaryTerms": {
                        "type": "array",
                        "items": { "type": "string" },
                        "description": "Žodynėlio termino pavadinimas kiekvienam item (nuoroda į žodyną)"
                      }
                    }
                  },
                  "celebrationText": {
                    "type": "string",
                    "description": "Teigiamas stiprinimas prieš recap (įsiminimo skaidrėms)"
                  },
                  "nextSteps": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Kas toliau – trumpi punktai"
                  },
                  "spinoffCta": {
                    "type": "object",
                    "properties": {
                      "label": { "type": "string" },
                      "url": { "type": "string" }
                    },
                    "description": "Nuoroda į spinoff / išorinį išteklių"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "path-step" } },
            "required": ["type"]
          },
          "then": {
            "required": ["content"],
            "properties": {
              "content": {
                "type": "object",
                "required": ["title", "stepNumber"],
                "description": "Kelio žingsnis – Duomenų analizės kelias pramaišytas su teorija; badge atrakina žodynėlio terminus",
                "properties": {
                  "title": { "type": "string" },
                  "pathLabel": {
                    "type": "string",
                    "description": "Kelio pavadinimas badge'e; jei nėra, UI naudoja M7 default"
                  },
                  "stepNumber": { "type": "number", "minimum": 1 },
                  "stepTotal": {
                    "type": "number",
                    "minimum": 1,
                    "description": "Rodoma „Žingsnis N / M“ (pvz. M7 kelias)"
                  },
                  "body": { "type": "string" },
                  "sections": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "heading": { "type": "string" },
                        "body": { "type": "string" },
                        "copyable": { "type": "string" }
                      }
                    }
                  },
                  "unlockedGlossaryTerms": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Terminų pavadinimai – atrakinti žodynėlyje po žingsnio užbaigimo"
                  },
                  "footer": { "type": "string" }
                }
              }
            }
          }
        }
      ]
    },
    "practiceScenarioHubContent": {
      "type": "object",
      "required": ["level1Choices", "level2Choices"],
      "properties": {
        "optionalPathNote": {
          "type": "string",
          "description": "Banner above hub – main path vs optional library"
        },
        "recommendedSlideIds": {
          "type": "array",
          "items": { "type": "number" },
          "description": "Soft-recommended hub scenario ids (amber badge)"
        },
        "level1Choices": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "type": "object",
            "required": ["id", "title", "description"],
            "properties": {
              "id": { "type": "number" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "icon": { "$ref": "#/$defs/scenarioHubIconKey" }
            }
          }
        },
        "level2Choices": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
