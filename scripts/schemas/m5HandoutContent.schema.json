{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "m5HandoutContent.json / m5HandoutContent-en.json",
  "type": "object",
  "required": [
    "title",
    "subtitle",
    "toolsIntro",
    "toolsBullets",
    "structure8",
    "masterPrompt",
    "fullPromptPrinciple",
    "sequenceSteps",
    "briefDefinition",
    "qualityCheckPoints",
    "thresholdsExplanation",
    "footerText"
  ],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "subtitle": { "type": "string", "minLength": 1 },
    "toolsIntro": { "type": "string", "minLength": 1 },
    "toolsBullets": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "structure8": { "type": "string", "minLength": 1 },
    "masterPrompt": { "type": "string", "minLength": 1 },
    "fullPromptPrinciple": { "type": "string", "minLength": 1 },
    "sequenceSteps": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "briefDefinition": { "type": "string", "minLength": 1 },
    "qualityCheckPoints": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "thresholdsExplanation": { "type": "string", "minLength": 1 },
    "footerText": { "type": "string", "minLength": 1 }
  }
}
