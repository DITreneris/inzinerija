{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "m4HandoutContent.json / m4HandoutContent-en.json",
  "type": "object",
  "required": [
    "title",
    "subtitle",
    "coreTopics",
    "checklist",
    "starterPrompt",
    "footerText"
  ],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "subtitle": { "type": "string", "minLength": 1 },
    "coreTopics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "meaning"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "meaning": { "type": "string", "minLength": 1 }
        }
      }
    },
    "checklist": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "starterPrompt": { "type": "string", "minLength": 1 },
    "footerText": { "type": "string", "minLength": 1 }
  }
}
