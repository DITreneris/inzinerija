{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "m6HandoutContent.json / m6HandoutContent-en.json",
  "type": "object",
  "required": [
    "title",
    "subtitle",
    "projectSteps",
    "dataManagementPoints",
    "reflectionSummary",
    "footerText"
  ],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "subtitle": { "type": "string", "minLength": 1 },
    "projectSteps": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "dataManagementPoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "practicalMeaning"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "practicalMeaning": { "type": "string", "minLength": 1 }
        }
      }
    },
    "reflectionSummary": { "type": "string", "minLength": 1 },
    "footerText": { "type": "string", "minLength": 1 }
  }
}
