{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "M7 Journey Overlay (modules-journey-m7.json)",
  "type": "object",
  "required": ["moduleId", "version", "fields"],
  "additionalProperties": false,
  "properties": {
    "moduleId": { "type": "integer", "const": 7 },
    "version": { "type": "integer", "minimum": 1 },
    "locale": { "type": "string", "enum": ["lt", "en"] },
    "fields": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "string", "minLength": 1 },
          "properties": {
            "pardavimai": { "type": "string", "minLength": 1 },
            "rinkodara": { "type": "string", "minLength": 1 },
            "it-inzinerija": { "type": "string", "minLength": 1 },
            "personalas": { "type": "string", "minLength": 1 },
            "vadyba": { "type": "string", "minLength": 1 },
            "kita": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
