# Magic link prieigos tikrinimas (reikia serverio: Vercel, Netlify, Cloudflare Workers)
ACCESS_TOKEN_SECRET=changeme_min16chars

# Verify-access origin/base URL (pvz. https://promptanatomy.app; tuščia = same-origin /api/verify-access).
# Runtime taip pat priima pilną endpoint URL dėl backward compatibility.
VITE_VERIFY_ACCESS_URL=

# Viešas marketingo domenas (OG/canonical build metu). Be jo – https://www.promptanatomy.app
# GitHub Pages profilis: VITE_PUBLIC_SITE_URL=https://ditreneris.github.io
VITE_PUBLIC_SITE_URL=https://www.promptanatomy.app

# Modulio prieigos ribojimas (0|3|6|9|12; tuščia = 0). Production: NENUSTATYTI demo reikšmės.
VITE_MAX_ACCESSIBLE_MODULE=

# Demo / GitHub Pages (M1-6 bundle): VITE_MVP_MODE=1
# Production M1-9 (Vercel monorepo): BE VITE_MVP_MODE, npm run build:production
# VITE_MAX_BUILD_MODULE=9

# Statinio hosting base path – turi atitikti deploy kelią.
# Production monorepo (promptanatomy.app): VITE_BASE_PATH=/anatomy/
# GitHub Pages (DITreneris/inzinerija): VITE_BASE_PATH=/inzinerija/
VITE_BASE_PATH=/anatomy/
