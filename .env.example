# Magic link prieigos tikrinimas (reikia serverio: Vercel, Netlify, Cloudflare Workers)
ACCESS_TOKEN_SECRET=changeme_min16chars

# Verify-access origin/base URL (pvz. https://promptanatomy.app; tuščia = same-origin /api/verify-access).
# Runtime taip pat priima pilną endpoint URL dėl backward compatibility.
VITE_VERIFY_ACCESS_URL=

# Modulio prieigos ribojimas (0|3|6|9|12; tuščia = 0)
VITE_MAX_ACCESSIBLE_MODULE=

# Core production profile: buildina tik modulius 1-6 (1 = įjungta)
VITE_MVP_MODE=1

# Statinio hosting base path – turi atitikti repo pavadinimą (GitHub Pages: https://<user>.github.io/<repo>/ → /<repo>/)
# Šis repo: inzinerija → VITE_BASE_PATH=/inzinerija/
VITE_BASE_PATH=/inzinerija/
