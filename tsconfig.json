{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@modules-data": ["src/data/modules.json"],
      "@glossary-data": ["src/data/glossary.json"],
      "@tools-data": ["src/data/tools.json"],
      "@tools-en-data": ["src/data/tools-en.json"],
      "@m9-characters-data": ["src/data/m9Characters.json"],
      "@ai-detectors-slide": ["src/components/AiDetectorsSlide.tsx"],
      "@vaizdo-generatorius-slide": ["src/components/VaizdoGeneratoriusSlide.tsx"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src", "src/**/*.test.ts", "src/**/*.test.tsx", "vite-env.d.ts"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
